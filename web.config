<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
                <add value="index.html" />
                <add value="default.htm" />
            </files>
        </defaultDocument>
        <rewrite>
            <rules>
                <clear />
                <rule name="API Endpoints">
                    <match url="(API/.*)" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="{R:1}.php" />
                </rule>
                <rule name="force secure" enabled="true" patternSyntax="Wildcard" stopProcessing="true">
                    <match url="*" />
                    <conditions logicalGrouping="MatchAny" trackAllCaptures="false">
                        <add input="{HTTPS}" pattern="off" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}{REQUEST_URI}" redirectType="Found" />
                </rule>
                <rule name="www to non" enabled="false" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false">
                        <add input="{HTTP_HOST}" pattern="^fiainspectors\.com$" negate="true" />
                    </conditions>
                    <action type="Redirect" url="https://fiainspectors.com/{R:1}" />
                </rule>
                <rule name="about-us" patternSyntax="ExactMatch">
                    <match url="about-us" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
                    <action type="Rewrite" url="about-us.php" />
                </rule>
                <rule name="inspections" patternSyntax="ExactMatch">
                    <match url="inspections" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
                    <action type="Rewrite" url="inspections.php" />
                </rule>
                <rule name="opportunities" patternSyntax="ExactMatch">
                    <match url="opportunities" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
                    <action type="Rewrite" url="opportunities.php" />
                </rule>
                <rule name="appraisals" patternSyntax="ExactMatch">
                    <match url="appraisals" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
                    <action type="Rewrite" url="appraisals.php" />
                </rule>
                <rule name="Guidelines" patternSyntax="ExactMatch">
                    <match url="inspector-guidelines" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
                    <action type="Rewrite" url="guidelines.php" />
                </rule>
            </rules>
        </rewrite>
        <security>
            <requestFiltering>
                <!-- 150 MB — covers photo uploads (20 MB max each) and short inspection videos (≤150 MB) -->
                <requestLimits maxAllowedContentLength="157286400" />
            </requestFiltering>
        </security>
    </system.webServer>
</configuration>
