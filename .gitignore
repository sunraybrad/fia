# ============================================================
# FIA - .gitignore
# ============================================================

# ------------------------------------------------------------
# Credentials & Environment Config
# ------------------------------------------------------------
# If you create a .env file later
.env
.env.*

# ------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------
.vscode/

# ------------------------------------------------------------
# Composer vendor directory (install via: composer install)
# ------------------------------------------------------------
vendor/

# ------------------------------------------------------------
# Claude AI config (local dev tooling only)
# ------------------------------------------------------------
.claude/
office/sql/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
_md/

# ------------------------------------------------------------
# OS junk
# ------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# ------------------------------------------------------------
# PHP temp / session files
# ------------------------------------------------------------
*.session

# ------------------------------------------------------------
# Captcha files
# ------------------------------------------------------------
captcha*.*

# ------------------------------------------------------------
# SQL files
# ------------------------------------------------------------
*.sql